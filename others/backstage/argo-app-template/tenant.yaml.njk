apiVersion: argoproj.io/v1alpha1
kind: Application
metadata:
  name: tenant-${{ values.tenant | lower }}
  namespace: argocd
spec:
  project: default
  source:
    repoURL: https://github.com/Arubacloud/devops-italy-2026.git
    targetRevision: HEAD
    path: argocd/applications/${{ values.tenant }}
    directory:
      recurse: true
  destination:
    server: https://kubernetes.default.svc
    namespace: tenant-${{ values.tenant | lower }}
  syncPolicy:
    automated:
      prune: true
      selfHeal: true
    syncOptions:
      - CreateNamespace=true
